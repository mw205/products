            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const userId = response.data ? response.data._id : response._id;",
                  "if (userId) {",
                  "    pm.collectionVariables.set(\"userId\", userId);",
                  "    console.log(\"User ID saved successfully:\", userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "const token = response.data ? response.data.access_token : response.access_token;",
                  "if (token) {",
                  "    pm.collectionVariables.set(\"token\", token);",
                  "    console.log(\"Access token saved successfully!\");",
                  "}",
                  "const userId = response.data ? response.data._id : response._id;",
                  "if (userId) {",
                  "    pm.collectionVariables.set(\"userId\", userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
